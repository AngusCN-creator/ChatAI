<?xml version="1.0" encoding="utf-8" standalone="no"?>
<Project ToolsVersion="14.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup Condition=" '$(ExcludeRestorePackageImports)' != 'true' ">
    <RestoreSuccess Condition=" '$(RestoreSuccess)' == '' ">False</RestoreSuccess>
    <RestoreTool Condition=" '$(RestoreTool)' == '' ">NuGet</RestoreTool>
    <ProjectAssetsFile Condition=" '$(ProjectAssetsFile)' == '' ">$(MSBuildThisFileDirectory)project.assets.json</ProjectAssetsFile>
    <NuGetPackageRoot Condition=" '$(NuGetPackageRoot)' == '' ">$(UserProfile)\.nuget\packages\</NuGetPackageRoot>
    <NuGetPackageFolders Condition=" '$(NuGetPackageFolders)' == '' ">C:\Users\angus\.nuget\packages\;G:\Setup\VisualStudio2026\Shared\NuGetPackages</NuGetPackageFolders>
    <NuGetProjectStyle Condition=" '$(NuGetProjectStyle)' == '' ">PackageReference</NuGetProjectStyle>
    <NuGetToolVersion Condition=" '$(NuGetToolVersion)' == '' ">7.0.0</NuGetToolVersion>
  </PropertyGroup>
  <ItemGroup Condition=" '$(ExcludeRestorePackageImports)' != 'true' ">
    <SourceRoot Include="C:\Users\angus\.nuget\packages\" />
    <SourceRoot Include="G:\Setup\VisualStudio2026\Shared\NuGetPackages\" />
  </ItemGroup>
  <ImportGroup Condition=" '$(ExcludeRestorePackageImports)' != 'true' ">
    <Import Project="$(NuGetPackageRoot)llamasharp.backend.cpu\0.27.0\build\netstandard2.0\LLamaSharp.Backend.Cpu.props" Condition="Exists('$(NuGetPackageRoot)llamasharp.backend.cpu\0.27.0\build\netstandard2.0\LLamaSharp.Backend.Cpu.props')" />
    <Import Project="$(NuGetPackageRoot)llamasharp.backend.vulkan.windows\0.27.0\build\netstandard2.0\LLamaSharp.Backend.Vulkan.Windows.props" Condition="Exists('$(NuGetPackageRoot)llamasharp.backend.vulkan.windows\0.27.0\build\netstandard2.0\LLamaSharp.Backend.Vulkan.Windows.props')" />
    <Import Project="$(NuGetPackageRoot)llamasharp.backend.vulkan.linux\0.27.0\build\netstandard2.0\LLamaSharp.Backend.Vulkan.Linux.props" Condition="Exists('$(NuGetPackageRoot)llamasharp.backend.vulkan.linux\0.27.0\build\netstandard2.0\LLamaSharp.Backend.Vulkan.Linux.props')" />
    <Import Project="$(NuGetPackageRoot)llamasharp.backend.vulkan\0.27.0\build\netstandard2.0\LLamaSharp.Backend.Vulkan.props" Condition="Exists('$(NuGetPackageRoot)llamasharp.backend.vulkan\0.27.0\build\netstandard2.0\LLamaSharp.Backend.Vulkan.props')" />
  </ImportGroup>
</Project>