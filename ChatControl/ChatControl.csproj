<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <Compile Update="Controls\ChatMainControl.cs">
      <SubType>UserControl</SubType>
    </Compile>
    <Compile Update="Controls\ChatMainControl.Designer.cs">
      <DependentUpon>ChatMainControl.cs</DependentUpon>
    </Compile>
    <EmbeddedResource Update="Controls\ChatMainControl.resx">
      <DependentUpon>ChatMainControl.cs</DependentUpon>
      <SubType>Designer</SubType>
    </EmbeddedResource>
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Forms\" />
  </ItemGroup>

</Project>
